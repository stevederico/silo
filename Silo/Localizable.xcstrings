    "On-device speech recognition is not available for this language. Download the language in Settings → General → Keyboard → Dictation, then try again.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此语言不支持设备端语音识别。请在“设置”→“通用”→“键盘”→“听写”中下载该语言，然后重试。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraakherkenning op het apparaat is niet beschikbaar voor deze taal. Download de taal in Instellingen → Algemeen → Toetsenbord → Dicteren, en probeer opnieuw."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Talegenkendelse på enheden er ikke tilgængelig for dette sprog. Download sproget under Indstillinger → Generelt → Tastatur → Diktering, og prøv igen."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepoznavanje govora na uređaju nije dostupno za ovaj jezik. Preuzmite jezik u Postavke → Općenito → Tipkovnica → Diktat, zatim pokušajte ponovno."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التعرّف على الكلام على الجهاز غير متاح لهذه اللغة. حمّل اللغة في الإعدادات → عام → لوحة المفاتيح → الإملاء، ثم حاول مرة أخرى."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此語言不支援裝置上語音辨識。請在「設定」→「一般」→「鍵盤」→「聽寫」下載該語言，然後再試一次。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El reconeixement de veu al dispositiu no està disponible per a aquest idioma. Descarrega l'idioma a Configuració → General → Teclat → Dictat i torna-ho a provar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozpoznávání řeči na zařízení není pro tento jazyk k dispozici. Stáhněte jazyk v Nastavení → Obecné → Klávesnice → Diktování a zkuste to znovu."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Laitteella tapahtuva puheentunnistus ei ole saatavilla tälle kielelle. Lataa kieli kohdassa Asetukset → Yleiset → Näppäimistö → Sanelu ja yritä uudelleen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die geräteinterne Spracherkennung ist für diese Sprache nicht verfügbar. Lade die Sprache unter Einstellungen → Allgemein → Tastatur → Diktieren herunter und versuche es erneut."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La reconnaissance vocale sur l’appareil n’est pas disponible pour cette langue. Téléchargez la langue dans Réglages → Général → Clavier → Dictée, puis réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この言語ではデバイス上の音声認識が利用できません。設定 → 一般 → キーボード → 音声入力で言語をダウンロードしてから、もう一度お試しください。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengenalan ucapan di perangkat tidak tersedia untuk bahasa ini. Unduh bahasa di Pengaturan → Umum → Papan Ketik → Dikte, lalu coba lagi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A készüléken belüli beszédfelismerés nem érhető el ehhez a nyelvhez. Töltsd le a nyelvet a Beállítások → Általános → Billentyűzet → Diktálás menüben, majd próbáld újra."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αναγνώριση ομιλίας στη συσκευή δεν είναι διαθέσιμη για αυτή τη γλώσσα. Κατεβάστε τη γλώσσα στις Ρυθμίσεις → Γενικά → Πληκτρολόγιο → Υπαγόρευση και δοκιμάστε ξανά."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस भाषा के लिए ऑन-डिवाइस स्पीच रिकग्निशन उपलब्ध नहीं है। Settings → General → Keyboard → Dictation में भाषा डाउनलोड करें, फिर पुनः प्रयास करें।"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "זיהוי דיבור במכשיר אינו זמין לשפה זו. הורד את השפה בהגדרות → כללי → מקלדת → הכתבה, ואז נסה שוב."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il riconoscimento vocale sul dispositivo non è disponibile per questa lingua. Scarica la lingua in Impostazioni → Generali → Tastiera → Dettatura, poi riprova."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengecaman pertuturan di peranti tidak tersedia untuk bahasa ini. Muat turun bahasa dalam Tetapan → Umum → Papan Kekunci → Dikte, kemudian cuba lagi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La reconnaissance vocale sur l’appareil n’est pas disponible pour cette langue. Téléchargez la langue dans Réglages → Général → Clavier → Dictée, puis réessayez."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozpoznawanie mowy na urządzeniu nie jest dostępne dla tego języka. Pobierz język w Ustawienia → Ogólne → Klawiatura → Dyktowanie, a następnie spróbuj ponownie."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 언어에 대해 기기 내 음성 인식이 지원되지 않습니다. 설정 → 일반 → 키보드 → 받아쓰기에서 언어를 다운로드한 후 다시 시도하세요."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O reconhecimento de fala no dispositivo não está disponível para este idioma. Transfira o idioma em Definições → Geral → Teclado → Ditado e tente novamente."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Talegjenkjenning på enheten er ikke tilgjengelig for dette språket. Last ned språket i Innstillinger → Generelt → Tastatur → Diktering, og prøv igjen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Распознавание речи на устройстве недоступно для этого языка. Загрузите язык в Настройки → Основные → Клавиатура → Диктовка, затем попробуйте снова."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozpoznávanie reči na zariadení nie je pre tento jazyk dostupné. Stiahnite jazyk v Nastavenia → Všeobecné → Klávesnica → Diktovanie a skúste znova."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O reconhecimento de fala no dispositivo não está disponível para este idioma. Baixe o idioma em Ajustes → Geral → Teclado → Ditado e tente novamente."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การรู้จำเสียงพูดบนอุปกรณ์ไม่พร้อมใช้งานสำหรับภาษานี้ ดาวน์โหลดภาษาใน การตั้งค่า → ทั่วไป → คีย์บอร์ด → การเขียนตามคำบอก แล้วลองอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu dil için cihazda konuşma tanıma kullanılamıyor. Ayarlar → Genel → Klavye → Dikte’den dili indirin, sonra tekrar deneyin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El reconocimiento de voz en el dispositivo no está disponible para este idioma. Descarga el idioma en Ajustes → General → Teclado → Dictado y vuelve a intentarlo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Recunoașterea vorbirii pe dispozitiv nu este disponibilă pentru această limbă. Descarcă limba în Setări → General → Tastatură → Dictare, apoi încearcă din nou."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Taligenkänning på enheten är inte tillgänglig för det här språket. Ladda ner språket i Inställningar → Allmänt → Tangentbord → Diktering, och försök igen."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El reconocimiento de voz en el dispositivo no está disponible para este idioma. Descarga el idioma en Ajustes → General → Teclado → Dictado y vuelve a intentarlo."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhận dạng giọng nói trên thiết bị không khả dụng cho ngôn ngữ này. Tải ngôn ngữ trong Cài đặt → Cài đặt chung → Bàn phím → Dictation, rồi thử lại."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розпізнавання мовлення на пристрої недоступне для цієї мови. Завантажте мову в Параметри → Основні → Клавіатура → Диктування, потім спробуйте знову."
          }

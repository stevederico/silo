    "Reads assistant replies aloud using on-device speech synthesis.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用设备端语音合成朗读助手回复。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Leest antwoorden van de assistent hardop voor met spraaksynthese op het apparaat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Læser assistentens svar højt ved hjælp af talesyntese på enheden."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Čita odgovore asistenta naglas koristeći sintezu govora na uređaju."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقرأ ردود المساعد بصوت عالٍ باستخدام تركيب الكلام على الجهاز."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用裝置上語音合成朗讀助理回覆。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegeix les respostes de l'assistent en veu alta mitjançant la síntesi de veu al dispositiu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čte odpovědi asistenta nahlas pomocí syntézy řeči na zařízení."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lukee avustajan vastaukset ääneen käyttäen laitteella tapahtuvaa puhesynteesiä."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest Antworten des Assistenten mit geräteinterner Sprachsynthese vor."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit les réponses de l’assistant à voix haute à l’aide de la synthèse vocale sur l’appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上の音声合成を使用してアシスタントの返信を読み上げます。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Membacakan balasan asisten dengan keras menggunakan sintesis ucapan di perangkat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az asszisztens válaszait hangosan felolvassa a készüléken belüli beszédszintézissel."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαβάζει δυνατά τις απαντήσεις του βοηθού με σύνθεση ομιλίας στη συσκευή."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऑन-डिवाइस स्पीच सिंथेसिस का उपयोग करके सहायक के जवाब ज़ोर से पढ़ता है।"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קורא את תשובות העוזר בקול באמצעות סינתזת דיבור במכשיר."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Legge ad alta voce le risposte dell'assistente usando la sintesi vocale sul dispositivo."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Membaca balasan pembantu dengan kuat menggunakan sintesis pertuturan di peranti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit les réponses de l’assistant à voix haute à l’aide de la synthèse vocale sur l’appareil."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odczytuje odpowiedzi asystenta na głos za pomocą syntezy mowy na urządzeniu."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기 내 음성 합성을 사용하여 어시스턴트 답변을 소리 내어 읽습니다."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Lê as respostas do assistente em voz alta usando síntese de fala no dispositivo."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Leser assistentens svar høyt med talesyntese på enheten."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Озвучивает ответы ассистента с помощью синтеза речи на устройстве."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Číta odpovede asistenta nahlas pomocou syntézy reči na zariadení."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",

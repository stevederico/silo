    "No Simulator-sized model found. Open Manage Models and download LFM2.5 (1.2 GB), or wait for the automatic download.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到适合 Simulator 的模型。打开 Manage Models 并下载 LFM2.5 (1.2 GB)，或等待自动下载。"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenalezen model pro Simulator. Otevřete Manage Models a stáhněte LFM2.5 (1.2 GB), nebo počkejte na automatické stažení."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "找不到適合 Simulator 大小的模型。請開啟 Manage Models 並下載 LFM2.5（1.2 GB），或等待自動下載。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم العثور على نموذج بحجم مناسب لـ Simulator. افتح Manage Models وقم بتنزيل LFM2.5 (1.2 GB)، أو انتظر التنزيل التلقائي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No s'ha trobat cap model de la mida del Simulator. Obre Manage Models i descarrega LFM2.5 (1.2 GB), o espera la descàrrega automàtica."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen model i Simulator-størrelse fundet. Åbn Manage Models og download LFM2.5 (1.2 GB), eller vent på den automatiske download."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen model van Simulator-formaat gevonden. Open Manage Models en download LFM2.5 (1.2 GB), of wacht op de automatische download."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije pronađen model veličine za Simulator. Otvorite Manage Models i preuzmite LFM2.5 (1.2 GB), ili pričekajte automatsko preuzimanje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun modèle de taille Simulator trouvé. Ouvrez Manage Models et téléchargez LFM2.5 (1.2 GB), ou attendez le téléchargement automatique."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν βρέθηκε μοντέλο μεγέθους Simulator. Ανοίξτε το Manage Models και κατεβάστε το LFM2.5 (1.2 GB), ή περιμένετε την αυτόματη λήψη."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun modèle de taille Simulator trouvé. Ouvrez Manage Models et téléchargez LFM2.5 (1,2 Go), ou attendez le téléchargement automatique."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Simulator-kokoista mallia ei löytynyt. Avaa Manage Models ja lataa LFM2.5 (1.2 GB) tai odota automaattista latausta."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לא נמצא מודל בגודל Simulator. פתח את Manage Models והורד LFM2.5 (1.2 GB), או המתן להורדה האוטומטית."
          }

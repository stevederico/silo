    "Model is reloading after transcription. Wait a moment.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "转录后模型正在重新加载。请稍候。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Model wordt herladen na transcriptie. Even wachten."
          }
        },
        "da": {
          "stringUnit": {

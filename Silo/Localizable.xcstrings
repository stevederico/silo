        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune parole détectée. Utilisez une vidéo avec un audio parlé clair et téléchargez un modèle Whisper dans Gérer les modèles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声が検出されませんでした。はっきりした音声のある動画を使用し、「モデルを管理」でWhisperモデルをダウンロードしてください。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada ucapan terdeteksi. Gunakan video dengan audio ucapan yang jelas dan unduh model Whisper di Kelola Model."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nem észlelhető beszéd. Használj tiszta beszédet tartalmazó videót, és tölts le egy Whisper modellt a Modellek kezelése menüben."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν εντοπίστηκε ομιλία. Χρησιμοποιήστε βίντεο με καθαρό προφορικό ήχο και κατεβάστε ένα μοντέλο Whisper στη Διαχείριση μοντέλων."
          }
        },
        "hi": {
          "stringUnit": {

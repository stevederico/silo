          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee en voz alta las respuestas del asistente mediante síntesis de voz en el dispositivo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",

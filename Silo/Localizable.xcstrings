    "Transcription finished but no transcript was saved. Try a video with clearer speech.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "转录完成但未保存转录文本。请尝试语音更清晰的视频。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcriptie voltooid maar er is geen transcript opgeslagen. Probeer een video met duidelijkere spraak."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Transskription afsluttet, men ingen transskription blev gemt. Prøv en video med klarere tale."

    "The current language is not supported for on-device recognition.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前语言不支持设备端识别。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De huidige taal wordt niet ondersteund voor herkenning op het apparaat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det aktuelle sprog understøttes ikke til genkendelse på enheden."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trenutni jezik nije podržan za prepoznavanje na uređaju."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اللغة الحالية غير مدعومة للتعرّف على الجهاز."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前語言不支援裝置上辨識。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'idioma actual no és compatible amb el reconeixement al dispositiu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuální jazyk není podporován pro rozpoznávání na zařízení."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nykyistä kieltä ei tueta laitteella tapahtuvassa tunnistuksessa."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die aktuelle Sprache wird für die geräteinterne Erkennung nicht unterstützt."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue actuelle n’est pas prise en charge pour la reconnaissance sur l’appareil."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の言語はデバイス上の認識に対応していません。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bahasa saat ini tidak didukung untuk pengenalan di perangkat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A jelenlegi nyelv nem támogatott a készüléken belüli felismeréshez."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η τρέχουσα γλώσσα δεν υποστηρίζεται για αναγνώριση στη συσκευή."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वर्तमान भाषा ऑन-डिवाइस रिकग्निशन के लिए समर्थित नहीं है।"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השפה הנוכחית אינה נתמכת לזיהוי במכשיר."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La lingua attuale non è supportata per il riconoscimento sul dispositivo."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bahasa semasa tidak disokong untuk pengecaman di peranti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue actuelle n’est pas prise en charge pour la reconnaissance sur l’appareil."
          }
        },
        "pl": {

          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อ่านคำตอบของผู้ช่วยออกเสียงโดยใช้การสังเคราะห์เสียงบนอุปกรณ์"
          }
        },
        "tr": {
          "stringUnit": {

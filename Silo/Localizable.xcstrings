    "Larger context allows longer conversations but uses more memory. Model will reload on change.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更大的上下文可支持更长的对话，但会占用更多内存。更改后模型将重新加载。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Grotere context maakt langere gesprekken mogelijk maar gebruikt meer geheugen. Model wordt herladen bij wijziging."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Større kontekst tillader længere samtaler, men bruger mere hukommelse. Modellen genindlæses ved ændring."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veći kontekst omogućuje duže razgovore, ali troši više memorije. Model će se ponovno učitati pri promjeni."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح السياق الأكبر بمحادثات أطول لكنه يستخدم ذاكرة أكثر. سيُعاد تحميل النموذج عند التغيير."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較大的上下文可支援較長的對話，但會使用更多記憶體。變更後模型將重新載入。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Un context més gran permet converses més llargues però utilitza més memòria. El model es tornarà a carregar en canviar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Větší kontext umožňuje delší konverzace, ale spotřebovává více paměti. Model se při změně znovu načte."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suurempi konteksti mahdollistaa pidemmät keskustelut mutta käyttää enemmän muistia. Malli ladataan uudelleen muutoksen yhteydessä."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Größerer Kontext ermöglicht längere Gespräche, verbraucht aber mehr Speicher. Modell wird bei Änderung neu geladen."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Un contexte plus large permet des conversations plus longues, mais utilise plus de mémoire. Le modèle se rechargera en cas de changement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテキストを大きくすると長い会話が可能になりますが、メモリを多く使用します。変更するとモデルが再読み込みされます。"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Konteks yang lebih besar memungkinkan percakapan lebih panjang tetapi menggunakan lebih banyak memori. Model akan dimuat ulang saat diubah."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A nagyobb kontextus hosszabb beszélgetéseket tesz lehetővé, de több memóriát használ. A modell újratöltődik a változtatáskor."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μεγαλύτερο πλαίσιο επιτρέπει μεγαλύτερες συνομιλίες αλλά καταναλώνει περισσότερη μνήμη. Το μοντέλο θα επαναφορτωθεί με την αλλαγή."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बड़ा संदर्भ लंबे संवाद की अनुमति देता है लेकिन अधिक मेमोरी उपयोग करता है। बदलने पर मॉडल फिर से लोड होगा।"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקשר גדול יותר מאפשר שיחות ארוכות יותר אך צורך יותר זיכרון. המודל ייטען מחדש בעת שינוי."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un contesto più ampio consente conversazioni più lunghe ma usa più memoria. Il modello si ricaricherà al cambiamento."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Konteks lebih besar membolehkan perbualan lebih panjang tetapi menggunakan lebih banyak memori. Model akan dimuat semula apabila berubah."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un contexte plus large permet des conversations plus longues mais utilise plus de mémoire. Le modèle se rechargera en cas de changement."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Większy kontekst umożliwia dłuższe rozmowy, ale zużywa więcej pamięci. Model zostanie przeładowany po zmianie."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "더 큰 컨텍스트는 더 긴 대화를 허용하지만 메모리를 더 많이 사용합니다. 변경 시 모델이 다시 로드됩니다."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um contexto maior permite conversas mais longas, mas usa mais memória. O modelo será recarregado ao alterar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Større kontekst muliggjør lengre samtaler, men bruker mer minne. Modellen lastes på nytt ved endring."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Больший контекст позволяет вести более длинные разговоры, но использует больше памяти. Модель перезагрузится при изменении."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Väčší kontext umožňuje dlhšie konverzácie, ale spotrebúva viac pamäte. Model sa po zmene znova načíta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um contexto maior permite conversas mais longas, mas usa mais memória. O modelo será recarregado ao alterar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บริบทที่ใหญ่ขึ้นช่วยให้สนทนาได้นานขึ้นแต่ใช้หน่วยความจำมากขึ้น โมเดลจะโหลดใหม่เมื่อมีการเปลี่ยนแปลง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha büyük bağlam daha uzun sohbetlere izin verir ancak daha fazla bellek kullanır. Değişiklikte model yeniden yüklenecek."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un contexto más grande permite conversaciones más largas, pero usa más memoria. El modelo se recargará al cambiar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Un context mai mare permite conversații mai lungi, dar consumă mai multă memorie. Modelul se va reîncărca la schimbare."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Större kontext möjliggör längre konversationer men använder mer minne. Modellen laddas om vid ändring."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Un contexto más grande permite conversaciones más largas pero usa más memoria. El modelo se recargará al cambiar."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngữ cảnh lớn hơn cho phép hội thoại dài hơn nhưng tốn nhiều bộ nhớ hơn. Mô hình sẽ tải lại khi thay đổi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Більший контекст дозволяє довші розмови, але використовує більше пам’яті. Модель перезавантажиться після зміни."
          }
        }
      }
    },

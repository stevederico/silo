    "Speech recognition is not available on this device.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备不支持语音识别。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraakherkenning is niet beschikbaar op dit apparaat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Talegenkendelse er ikke tilgængelig på denne enhed."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepoznavanje govora nije dostupno na ovom uređaju."

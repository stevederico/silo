    "No speech detected. Use a video with clear spoken audio and download a Whisper model in Manage Models.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未检测到语音。请使用带有清晰语音的视频，并在“管理模型”中下载 Whisper 模型。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen spraak gedetecteerd. Gebruik een video met duidelijke gesproken audio en download een Whisper-model in Modellen beheren."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen tale registreret. Brug en video med klar talt lyd, og download en Whisper-model under Administrer modeller."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Govor nije detektiran. Koristite video s jasnim govorom i preuzmite Whisper model u Upravljanju modelima."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يُكتشف كلام. استخدم فيديو بصوت واضح وحمّل نموذج Whisper في إدارة النماذج."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未偵測到語音。請使用有清晰語音的影片，並在「管理模型」中下載 Whisper 模型。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
